generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Repository {
  id            String   @id @default(cuid())
  externalId    String?
  host          String   @default("github")
  fullName      String   @unique
  owner         String
  name          String
  url           String   @unique
  description   String?
  defaultBranch String?
  license       String?
  primaryLanguage String?
  stars         Int      @default(0)
  forks         Int      @default(0)
  watchers      Int      @default(0)
  openIssues    Int      @default(0)
  isArchived    Boolean  @default(false)
  lastCommitAt  DateTime?
  lastIndexedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  skills        Skill[]
  ingestionRuns IngestionRun[]

  @@index([host, owner, name])
}

model Skill {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  summary       String
  platform      String
  category      String
  domain        String
  complexity    String
  provenance    String
  riskLevel     String
  sourceKind    String   @default("github_repository")
  sourcePath    String
  sourceUrl     String
  installHint   String?
  ownerName     String
  isFeatured    Boolean  @default(false)
  heatScore     Float    @default(0)
  growthRate    Float    @default(0)
  qualityScore  Float    @default(0)
  lastIndexedAt DateTime
  lastVerifiedAt DateTime?
  repositoryId  String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  repository      Repository       @relation(fields: [repositoryId], references: [id], onDelete: Cascade)
  versions        SkillVersion[]
  classifications Classification[]
  rankingSnapshots RankingSnapshot[]
  favorites       Favorite[]

  @@index([platform])
  @@index([category])
  @@index([domain])
  @@index([repositoryId])
  @@index([heatScore])
}

model SkillVersion {
  id              String   @id @default(cuid())
  skillId         String
  versionLabel    String?
  sourcePath      String
  sourceSha       String?
  contentHash     String
  content         String
  extractedSummary String?
  metadataJson    String?
  discoveredAt    DateTime
  upstreamUpdatedAt DateTime?
  isLatest        Boolean  @default(true)
  createdAt       DateTime @default(now())

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, contentHash])
  @@index([skillId, isLatest])
}

model Classification {
  id           String   @id @default(cuid())
  skillId      String
  dimension    String
  value        String
  confidence   Float    @default(1)
  sourceMethod String
  createdAt    DateTime @default(now())

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, dimension, value])
  @@index([dimension, value])
}

model RankingSnapshot {
  id         String   @id @default(cuid())
  skillId    String
  board      String
  window     String
  rank       Int
  score      Float
  trendPct   Float?
  recordedAt DateTime
  factorsJson String?

  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, board, window, recordedAt])
  @@index([board, window, recordedAt, rank])
}

model User {
  id          String   @id @default(cuid())
  email       String?  @unique
  githubId    String?  @unique
  githubLogin String?  @unique
  name        String?
  imageUrl    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  favorites Favorite[]
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  skillId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
  @@index([skillId])
}

model IngestionRun {
  id                String   @id @default(cuid())
  sourceKind        String
  target            String
  status            String
  triggerMode       String
  repositoryId      String?
  discoveredCount   Int      @default(0)
  newSkillsCount    Int      @default(0)
  updatedSkillsCount Int     @default(0)
  startedAt         DateTime @default(now())
  finishedAt        DateTime?
  errorMessage      String?
  createdAt         DateTime @default(now())

  repository Repository? @relation(fields: [repositoryId], references: [id], onDelete: SetNull)

  @@index([sourceKind, status, startedAt])
}
